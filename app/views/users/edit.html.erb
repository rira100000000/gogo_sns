<div class="space-y-6">
  <div class="flex items-center space-x-2">
    <%= link_to "← 戻る", user_path(@user), class: "text-indigo-600 hover:underline" %>
    <h1 class="text-2xl font-bold text-indigo-600">プロフィール編集</h1>
  </div>

  <div class="bg-white p-6 rounded-lg border">
    <%= form_with(model: @user, local: true, class: "space-y-6") do |f| %>
      <% if @user.errors.any? %>
        <div class="bg-red-50 text-red-700 p-4 rounded-lg mb-4">
          <h2 class="font-bold mb-2"><%= pluralize(@user.errors.count, "error") %> 件のエラーがあります：</h2>
          <ul class="list-disc pl-5">
            <% @user.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="space-y-2">
        <label class="block text-gray-700 font-bold">ユーザー名</label>
        <%= f.text_field :username, class: "w-full border rounded-lg p-3" %>
      </div>

      <div class="space-y-2">
        <label class="block text-gray-700 font-bold">プロフィール</label>
        <%= f.text_area :profile, rows: 5, class: "w-full border rounded-lg p-3", placeholder: "自己紹介を入力してください" %>
      </div>

      <div class="text-center">
        <%= f.submit "更新する", class: "bg-indigo-600 text-white px-6 py-2 rounded-lg hover:bg-indigo-700" %>
      </div>
    <% end %>
  </div>

  <div class="bg-white p-6 rounded-lg border">
    <h2 class="text-xl font-bold text-gray-700 mb-4">アカウント設定</h2>
    <p class="mb-4">メールアドレスやパスワードを変更するには、以下のリンクをクリックしてください。</p>
    <%= link_to "アカウント設定を変更", edit_user_registration_path, class: "text-indigo-600 hover:underline" %>
  </div>
</div>
