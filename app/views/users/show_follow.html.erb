<div class="space-y-6">
  <div class="flex items-center space-x-2">
    <%= link_to "← 戻る", user_path(@user), class: "text-indigo-600 hover:underline" %>
    <h1 class="text-2xl font-bold text-indigo-600"><%= @user.username %>さんの<%= @title %></h1>
  </div>

  <div class="bg-white p-6 rounded-lg border">
    <div class="flex space-x-4 text-sm mb-4">
      <span>
        <span class="font-bold"><%= @user.posts.count %></span> 投稿
      </span>
      <span>
        <%= link_to following_user_path(@user), class: "hover:underline #{'font-bold' if @title == 'フォロー中'}" do %>
          <span class="font-bold"><%= @user.following.count %></span> フォロー中
        <% end %>
      </span>
      <span>
        <%= link_to followers_user_path(@user), class: "hover:underline #{'font-bold' if @title == 'フォロワー'}" do %>
          <span class="font-bold"><%= @user.followers.count %></span> フォロワー
        <% end %>
      </span>
    </div>

    <% if @users.present? %>
      <div class="space-y-4">
        <% @users.each do |user| %>
          <div class="border rounded-lg p-4 hover:bg-gray-50">
            <div class="flex justify-between items-center">
              <div>
                <h3 class="font-bold">
                  <%= link_to user.username, user_path(user), class: "text-indigo-600 hover:underline" %>
                </h3>
                <p class="text-gray-500 text-sm">投稿数: <%= user.posts.count %></p>
              </div>
              
              <% if user_signed_in? && current_user != user %>
                <% if current_user.following?(user) %>
                  <% follow = current_user.active_follows.find_by(followed_id: user.id) %>
                  <%= button_to "フォロー解除", follow_path(follow), method: :delete, class: "bg-gray-200 text-gray-800 px-3 py-1 rounded text-sm hover:bg-gray-300" %>
                <% else %>
                  <%= button_to "フォローする", follows_path(followed_id: user.id), method: :post, class: "bg-indigo-600 text-white px-3 py-1 rounded text-sm hover:bg-indigo-700" %>
                <% end %>
              <% end %>
            </div>
            
            <% if user.profile.present? %>
              <div class="mt-2 text-sm text-gray-600 line-clamp-2">
                <%= user.profile %>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
      
      <div class="my-4">
        <%= paginate @users %>
      </div>
    <% else %>
      <p class="text-gray-500 text-center py-4">
        <% if @title == 'フォロー中' %>
          まだ誰もフォローしていません。
        <% else %>
          まだフォロワーがいません。
        <% end %>
      </p>
    <% end %>
  </div>
</div>