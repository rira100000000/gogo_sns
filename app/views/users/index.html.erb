<h1 class="mb-4">ユーザー一覧</h1>

<div class="row">
  <% @users.each do |user| %>
    <div class="col-md-6 mb-4">
      <div class="card">
        <div class="card-body">
          <div class="d-flex justify-content-between align-items-center">
            <h5 class="card-title">
              <%= link_to user.username, user_path(user), class: "text-decoration-none" %>
            </h5>
            <% if user_signed_in? && current_user != user %>
              <% if current_user.following?(user) %>
                <%= button_to "フォロー解除", follow_path(current_user.active_follows.find_by(followed_id: user.id)), 
                    method: :delete, 
                    class: "btn btn-outline-primary btn-sm" %>
              <% else %>
                <%= button_to "フォローする", follows_path(followed_id: user.id), 
                    method: :post, 
                    class: "btn btn-primary btn-sm" %>
              <% end %>
            <% end %>
          </div>
          <% if user.profile.present? %>
            <p class="card-text text-muted"><%= truncate(user.profile, length: 100) %></p>
          <% else %>
            <p class="card-text text-muted">プロフィールはまだ設定されていません。</p>
          <% end %>
          <div class="mt-2">
            <small class="text-muted">
              投稿: <%= user.posts.count %> | 
              フォロー: <%= link_to user.following.count, following_user_path(user), class: "text-decoration-none" %> | 
              フォロワー: <%= link_to user.followers.count, followers_user_path(user), class: "text-decoration-none" %>
            </small>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>

<div class="d-flex justify-content-center mt-4">
  <%= paginate @users %>
</div>