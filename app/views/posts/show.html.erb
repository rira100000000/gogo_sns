<div class="mb-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <div class="d-flex align-items-center gap-2">
      <%= link_to "← 戻る", :back, class: "text-primary text-decoration-none" %>
      <h1 class="h2 text-primary mb-0">投稿詳細</h1>
    </div>
    <% if current_user == @post.user %>
      <div class="d-flex gap-2">
        <%= link_to "編集", edit_post_path(@post), class: "btn btn-outline-primary btn-sm" %>
        <%= button_to "削除", post_path(@post), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "btn btn-outline-danger btn-sm" %>
      </div>
    <% end %>
  </div>

  <div class="card mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-start">
        <div>
          <h2 class="h5 fw-bold">
            <%= link_to @post.user.username, user_path(@post.user), class: "text-primary text-decoration-none" %>
          </h2>
          <p class="text-muted small"><%= l @post.created_at, format: :long %></p>
        </div>
      </div>
      <div class="mt-3 font-monospace fs-5">
        <%= simple_format(@post.content) %>
      </div>
      
      <div class="mt-4">
        <% if user_signed_in? %>
          <% if @stamp %>
            <%= button_to post_stamp_path(@post, @stamp), method: :delete, class: "btn btn-outline-warning d-inline-flex align-items-center gap-1" do %>
              <i class="bi bi-star-fill"></i>
              <span>スタンプ済み (<%= @post.stamps.count %>)</span>
            <% end %>
          <% else %>
            <%= button_to post_stamps_path(@post), method: :post, class: "btn btn-outline-secondary d-inline-flex align-items-center gap-1" do %>
              <i class="bi bi-star"></i>
              <span>スタンプする (<%= @post.stamps.count %>)</span>
            <% end %>
          <% end %>
        <% else %>
          <div class="d-inline-flex align-items-center gap-1 text-muted">
            <i class="bi bi-star"></i>
            <span>スタンプ (<%= @post.stamps.count %>)</span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="mt-5">
    <h3 class="h4 fw-bold mb-4 border-bottom pb-2">コメント (<%= @comments.count %>)</h3>
    
    <% if user_signed_in? %>
      <div class="mb-4">
        <%= form_with(model: [@post, @comment], local: true, class: "mb-4") do |f| %>
          <div class="mb-3">
            <%= f.text_area :content, rows: 3, class: "form-control", placeholder: "コメントを入力..." %>
          </div>
          <div class="text-end">
            <%= f.submit "コメントする", class: "btn btn-primary" %>
          </div>
        <% end %>
      </div>
    <% end %>
    
    <div>
      <% if @comments.present? %>
        <% @comments.each do |comment| %>
          <div class="card mb-3">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start">
                <div>
                  <h4 class="h6 fw-bold">
                    <%= link_to comment.user.username, user_path(comment.user), class: "text-primary text-decoration-none" %>
                  </h4>
                  <p class="text-muted small"><%= l comment.created_at, format: :long %></p>
                </div>
                <% if current_user == comment.user %>
                  <%= button_to "削除", post_comment_path(@post, comment), method: :delete, data: { confirm: "本当に削除しますか？" }, class: "btn btn-outline-danger btn-sm" %>
                <% end %>
              </div>
              <div class="mt-2">
                <%= simple_format(comment.content) %>
              </div>
            </div>
          </div>
        <% end %>
      <% else %>
        <p class="text-muted text-center py-4">まだコメントがありません。</p>
      <% end %>
    </div>
  </div>
</div>
